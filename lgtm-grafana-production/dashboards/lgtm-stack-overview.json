{
  "title": "LGTM Production Stack Overview",
  "uid": "lgtm-production-stack-overview",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "30s",
  "tags": ["production-lab", "lgtm", "stack-overview"],
  "timezone": "browser",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Running Pods",
      "description": "Tong pod Running cua LGTM trong namespace observability va observability-agents.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_pod_status_phase{namespace=~\"observability|observability-agents\", phase=\"Running\"})",
          "legendFormat": "running"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphOrientation": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Restarts Last 1h",
      "description": "Tong restart cua cac container LGTM trong 1 gio gan nhat.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(kube_pod_container_status_restarts_total{namespace=~\"observability|observability-agents\"}[1h]))",
          "legendFormat": "restarts"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphOrientation": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bound PVCs",
      "description": "So persistent volumes dang Bound cho storage backend.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(kube_persistentvolumeclaim_status_phase{namespace=\"observability\", phase=\"Bound\"})",
          "legendFormat": "bound"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphOrientation": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Mimir Query OK",
      "description": "Datasource Mimir co nhin thay metrics remote_write tu Prometheus hay khong.",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "targets": [
        {
          "refId": "A",
          "expr": "count(up)",
          "legendFormat": "series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphOrientation": "auto",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "All LGTM Component Pods",
      "description": "Bang chinh de demo day du thanh phan: Grafana, Prometheus, Alertmanager, Loki, Tempo, Mimir, Alloy, MinIO.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 4, "w": 24, "h": 9},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (namespace, pod) (kube_pod_status_ready{namespace=~\"observability|observability-agents\", condition=\"true\"})",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {"Time": true, "__name__": true},
            "renameByName": {"Value": "ready", "namespace": "namespace", "pod": "component pod"}
          }
        }
      ],
      "options": {"showHeader": true, "cellHeight": "sm", "footer": {"show": false}},
      "fieldConfig": {"defaults": {"custom": {"align": "auto", "cellOptions": {"type": "auto"}}, "mappings": []}, "overrides": []}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Usage By Pod",
      "description": "CPU theo pod, dung de noi ve cost/resource cua tung thanh phan.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 13, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=~\"observability|observability-agents\", container!=\"\", image!=\"\"}[5m]))",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "cores", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 8, "showPoints": "never"}, "mappings": []}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory Usage By Pod",
      "description": "Memory working set theo pod.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 12, "y": 13, "w": 12, "h": 8},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=~\"observability|observability-agents\", container!=\"\", image!=\"\"})",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 8, "showPoints": "never"}, "mappings": []}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "PVC Usage Ratio",
      "description": "Ti le su dung PVC cua storage backend.",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"x": 0, "y": 21, "w": 12, "h": 7},
      "targets": [
        {
          "refId": "A",
          "expr": "kubelet_volume_stats_used_bytes{namespace=\"observability\"} / kubelet_volume_stats_capacity_bytes{namespace=\"observability\"}",
          "legendFormat": "{{persistentvolumeclaim}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 8, "showPoints": "never"}, "mappings": []}, "overrides": []},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"]}, "tooltip": {"mode": "multi", "sort": "desc"}}
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent LGTM Stack Logs",
      "description": "Logs gan nhat cua toan bo LGTM stack lay tu Loki.",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 12, "y": 21, "w": 12, "h": 7},
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=~\"observability|observability-agents\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
